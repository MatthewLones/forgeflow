{
  "name": "@forgeflow/engine",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./docker": {
      "types": "./dist/docker.d.ts",
      "import": "./dist/docker.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/docker.ts --format esm --dts",
    "dev": "tsup src/index.ts src/docker.ts --format esm --dts --watch"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@forgeflow/compiler": "workspace:*",
    "@forgeflow/skill-resolver": "workspace:*",
    "@forgeflow/state-store": "workspace:*",
    "@forgeflow/types": "workspace:*",
    "@forgeflow/validator": "workspace:*",
    "chokidar": "^4.0.0",
    "dockerode": "^4.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1"
  }
}
