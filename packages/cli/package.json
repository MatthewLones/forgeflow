{
  "name": "@forgeflow/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forgeflow": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "files": ["dist"],
  "dependencies": {
    "@forgeflow/types": "workspace:*",
    "@forgeflow/parser": "workspace:*",
    "@forgeflow/skill-resolver": "workspace:*",
    "@forgeflow/engine": "workspace:*",
    "@forgeflow/state-store": "workspace:*"
  }
}
